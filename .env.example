# Backend API Configuration
# Local development backend (e.g., uvicorn running on port 8001):
# VITE_API_BASE_URL=http://127.0.0.1:8001
#
# Production backend:
# VITE_API_BASE_URL=https://proctoring.formapply.in
VITE_API_BASE_URL=http://127.0.0.1:8001
VITE_API_KEY=your_api_key_here

# Optional: set true only if you want Vite to proxy /reports in local dev.
# Default behavior is direct browser calls to VITE_API_BASE_URL.
# For local backend with Vite proxy: VITE_USE_DEV_PROXY=true
# For direct backend calls: VITE_USE_DEV_PROXY=false
VITE_USE_DEV_PROXY=true

